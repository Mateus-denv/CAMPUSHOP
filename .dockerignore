# ============================================
# .dockerignore - CampuShop
# Arquivos e pastas a IGNORAR no build Docker
# ============================================

# ==========================================
# Build e Target (Maven)
# ==========================================
target/
!target/*.jar
*.class

# ==========================================
# Maven Local Repository
# ==========================================
.m2/
*.jar
*.war
*.ear
maven.zip

# ==========================================
# Java/JDK Locais (não necessários no container)
# ==========================================
oracleJdk-25/
apache-maven-3.9.6/

# ==========================================
# IDE Files
# ==========================================
# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/

# Eclipse
.classpath
.project
.settings/
bin/

# VS Code
.vscode/
*.code-workspace

# NetBeans
nbproject/
nb-configuration.xml

# ==========================================
# Git
# ==========================================
.git/
.gitignore
.gitattributes

# ==========================================
# Documentation (exceto README principal)
# ==========================================
*.md
!README.md
docs/
documentation/

# ==========================================
# Docker Files (não precisam ir para a imagem)
# ==========================================
Dockerfile*
docker-compose*.yml
.dockerignore
docker/

# ==========================================
# Scripts
# ==========================================
*.bat
*.ps1
*.sh
compile.*
run-docker.*
test-db.*

# ==========================================
# Logs
# ==========================================
logs/
*.log

# ==========================================
# Temporary Files
# ==========================================
tmp/
temp/
*.tmp
*.temp
*.swp
*.swo
*~

# ==========================================
# OS Files
# ==========================================
# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~

# ==========================================
# Environment Files
# ==========================================
.env
.env.local
.env.*.local
*.properties.local

# ==========================================
# Node (se houver frontend)
# ==========================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ==========================================
# Archives
# ==========================================
*.zip
*.tar.gz
*.rar
*.7z

# ==========================================
# License e outros arquivos desnecessários
# ==========================================
LICENSE
.github/
COMPILATION_ISSUES.md
GUIA_INSTALACAO_WINDOWS.md
INSTALACAO_RAPIDA.md
